rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /content/schedule {
      allow read: if true;
      allow write: if false;
    }
    match /content/imageOverrides {
      allow read: if true;
      allow write: if false;
    }
    match /content/maintenanceMode {
      allow read: if true;
      allow write: if false;
    }
    match /content/pageText {
      allow read: if true;
      allow write: if false;
    }
    match /content/siteConfig {
      allow read: if true;
      allow write: if false;
    }

    // Shared memories: public read.
    // Clients may only update likes/likedBy (increment likes by exactly 1).
    // Create/delete requires admin SDK (Netlify functions).
    match /sharedMemories/{id} {
      allow read: if true;
      allow create, delete: if false;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy'])
                    && request.resource.data.likes == resource.data.likes + 1;
    }

    // Comments subcollection: public read; writes via Netlify function only.
    match /sharedMemories/{id}/comments/{commentId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
