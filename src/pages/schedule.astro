---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScheduleContent from '../../content/calendar.md';
---

<BaseLayout title="Festival Schedule" description="Surf Del Mar Festival 4-day schedule — October 8–11, 2026." pageKey="schedule">
	<section class="hero schedule-hero">
		<div class="hero-content">
			<span class="eyebrow">4-Day Event</span>
			<h1 class="hero-title">Surf Del Mar Festival Schedule</h1>
			<p class="tagline">October 8–11, 2026</p>
		</div>
	</section>

	<section class="schedule-content" aria-label="Festival schedule">
		<div class="container schedule-inner">
			<div class="schedule-markdown">
				<ScheduleContent />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:root {
		--surf-blue-dark: #1a365d;
		--surf-blue-mid: #2c5282;
	}

	.hero.schedule-hero {
		padding: 5rem 2rem;
		text-align: center;
		background: linear-gradient(to bottom, #dbeafe, var(--color-foam));
		position: relative;
		overflow: hidden;
	}

	.schedule-hero .eyebrow {
		display: block;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--surf-blue-mid);
		margin-bottom: 0.5rem;
		font-family: var(--font-body);
	}

	.schedule-hero .hero-title {
		font-family: var(--font-display);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 600;
		color: var(--surf-blue-dark);
		margin: 0 0 0.5rem 0;
		line-height: 1.2;
	}

	.schedule-hero .tagline {
		font-size: 1.25rem;
		color: var(--surf-blue-mid);
		margin: 0;
		font-weight: 500;
	}

	.schedule-content {
		position: relative;
		z-index: 1;
		padding: 2rem 2rem 4rem;
		background: linear-gradient(to bottom, #dbeafe, var(--color-foam));
	}

	.schedule-inner {
		max-width: 920px;
		margin: 0 auto;
	}

	.schedule-markdown {
		background: rgba(255, 255, 255, 0.9);
		border: 1px solid rgba(44, 82, 130, 0.12);
		border-radius: 14px;
		padding: 1.5rem 1.75rem;
		font-size: 1rem;
		line-height: 1.7;
		color: var(--surf-blue-dark);
		box-shadow: 0 10px 28px rgba(26, 54, 93, 0.08);
	}

	.schedule-markdown :global(h1),
	.schedule-markdown :global(h2),
	.schedule-markdown :global(h3) {
		font-family: var(--font-display);
		font-weight: 700;
		color: var(--surf-blue-dark);
		margin: 1.2rem 0 0.5rem;
	}

	.schedule-markdown :global(h1:first-child),
	.schedule-markdown :global(h2:first-child),
	.schedule-markdown :global(h3:first-child) {
		margin-top: 0;
	}

	.schedule-markdown :global(h2) {
		font-size: clamp(1.3rem, 2.8vw, 1.7rem);
		padding-bottom: 0.35rem;
		border-bottom: 1px solid rgba(44, 82, 130, 0.14);
	}

	.schedule-markdown :global(ul) {
		margin: 0.5rem 0 1rem 1.1rem;
		padding: 0;
	}

	.schedule-markdown :global(li) {
		margin: 0.35rem 0;
	}

	.schedule-markdown :global(p) {
		margin: 0.45rem 0;
	}

	@media (max-width: 640px) {
		.schedule-content {
			padding: 1.5rem 1rem 2.5rem;
		}
		.schedule-markdown {
			padding: 1.1rem 1rem;
		}
	}
</style>
