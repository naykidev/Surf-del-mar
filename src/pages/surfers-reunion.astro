---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollWaves from '../components/ScrollWaves.astro';
import WaveSurfer from '../components/WaveSurfer.astro';
import PirateShip from '../components/PirateShip.astro';
import Lighthouse from '../components/Lighthouse.astro';
---

<BaseLayout
	title="Surfers Reunion"
	description="A gathering of generations—Del Mar surfers past and present, together again."
	pageKey="surfers-reunion"
>
	<section class="hero hero-sunset-bg">
		<div class="hero-content hero-entrance">
			<h1 class="hero-title" data-editable="reunion.hero.title">SURFERS REUNION</h1>
			<p class="tagline hero-tagline" data-editable="reunion.hero.tagline">A Gathering of Generations</p>
		</div>
	</section>
	<div class="wave-wrap wave-hero hero-sunset-bg" id="reunion-wave-wrap">
		<ScrollWaves variant="light" />
		<WaveSurfer />
		<PirateShip />
		<Lighthouse toggleTargetId="reunion-wave-wrap" />
	</div>

	<section class="reunion-content">
		<div class="container">
			<div class="reunion-intro-grid">
				<div class="reunion-intro-image-col">
					<div class="reunion-surfers-wrap">
						<img src="/surfers.jpg" alt="Surfers at Del Mar" class="reunion-surfers-img" width="600" height="400" />
					</div>
				</div>
				<div class="reunion-intro-text-col">
					<p class="reunion-intro" data-editable="reunion.intro1">
						For decades, surfers have gathered along our local beaches to ride the waves, and share stories, building a unique coastal culture. SURF DEL MAR brings these generations together again.
					</p>
					<p class="reunion-intro" data-editable="reunion.intro2">
						From the pioneers who surfed here in the 1930s, like XXXXXXX, and into the 1950s and 60s, to today's surfers and young riders, this reunion invites everyone connected to Del Mar and the surrounding surf communities to come together and celebrate.
					</p>
				</div>
			</div>

			<h2 class="reunion-subhead" data-editable="reunion.subhead1">REMEMBERING THE WAVES</h2>
			<p class="reunion-lead" data-editable="reunion.lead">Throughout the SURF DEL MAR weekend, reunion events will include;</p>
			<ul class="reunion-list">
				<li data-editable="reunion.list.1">Informal gatherings and storytelling with surfers from different eras</li>
				<li data-editable="reunion.list.2">Historic photographs and shared memories from Del Mar's early surf days</li>
				<li data-editable="reunion.list.3">Film screenings celebrating classic surf culture</li>
				<li data-editable="reunion.list.4">Music and community events bringing surfers, families and friends together</li>
			</ul>
			<article class="event-card">
				<p class="reunion-body" data-editable="reunion.body1">
					The reunion is about reconnecting with old friends, meeting new ones, and honoring the shared love of the ocean that has defined Del Mar and its neighbors for generations.
				</p>
			</article>

			<h2 class="reunion-subhead" data-editable="reunion.subhead2">BE PART OF THE REUNION:</h2>
			<article class="event-card">
				<p class="reunion-body" data-editable="reunion.body2">
					Just like the Beach Boys song says, "You'll catch 'em surfin' at Del Mar," whether you surfed these waves decades ago or just recently discovered them, SURF DEL MAR welcomes you! Come celebrate the history, the stories and the community that grew from the surf at Del Mar.
				</p>
			</article>

			<article class="event-card event-card-cta">
				<h2 class="reunion-cta-heading" data-editable="reunion.cta-heading">DO YOU HAVE A DEL MAR SURF STORY? SHARE IT WITH EVERYONE!</h2>
				<p class="reunion-cta-body" data-editable="reunion.cta-body">
					Send us your photos, your memories and names of people we should invite. We'll include them in the SHARED MEMORIES section below.
				</p>
				<button type="button" class="reunion-share-btn" id="reunion-share-memories-btn">Share your memories</button>
			</article>

			<h2 class="reunion-subhead reunion-memories-heading">SHARED MEMORIES</h2>
		</div>

		<!-- TikTok feed lives full-width outside the narrow container -->
		<div id="shared-memories-container" class="shared-memories-container" aria-live="polite">
			<p id="shared-memories-loading" class="shared-memories-msg">Loading…</p>
		</div>
	</section>

	<!-- Share memories modal -->
	<div id="share-memories-modal" class="share-memories-modal" role="dialog" aria-labelledby="share-memories-title" aria-modal="true" hidden>
		<div class="share-memories-overlay" id="share-memories-overlay"></div>
		<div class="share-memories-box">
			<h2 id="share-memories-title" class="share-memories-title">Share your memories</h2>
			<form id="share-memories-form" class="share-memories-form">
				<label for="memory-photo" class="share-memories-label">Photo</label>
				<input type="file" id="memory-photo" name="photo" accept="image/*" required class="share-memories-file" />
				<label for="memory-caption" class="share-memories-label">Your memory (optional)</label>
				<textarea id="memory-caption" name="caption" class="share-memories-textarea" rows="3" placeholder="Tell us about this photo…" maxlength="1000"></textarea>
				<label for="memory-name" class="share-memories-label">Your name (optional)</label>
				<input type="text" id="memory-name" name="name" class="share-memories-input" placeholder="Name" maxlength="200" />
				<p id="share-memories-error" class="share-memories-error" aria-live="polite" hidden></p>
				<p id="share-memories-success" class="share-memories-success" aria-live="polite" hidden>Thank you! Your memory has been added.</p>
				<div class="share-memories-actions">
					<button type="button" class="share-memories-btn share-memories-cancel" id="share-memories-cancel">Cancel</button>
					<button type="submit" class="share-memories-btn share-memories-submit" id="share-memories-submit">Submit</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		import { getSharedMemories } from '../lib/firebase';
		import type { SharedMemory } from '../lib/firebase';

		const SUBMIT_URL = '/.netlify/functions/submit-memory';
		const MAX_IMAGE_SIZE = 700 * 1024;
		const MAX_DIMENSION = 1200;

		// Share modal refs
		const openBtn       = document.getElementById('reunion-share-memories-btn');
		const shareModal    = document.getElementById('share-memories-modal');
		const shareOverlay  = document.getElementById('share-memories-overlay');
		const form          = document.getElementById('share-memories-form') as HTMLFormElement | null;
		const cancelBtn     = document.getElementById('share-memories-cancel');
		const fileInput     = document.getElementById('memory-photo') as HTMLInputElement;
		const errorEl       = document.getElementById('share-memories-error');
		const successEl     = document.getElementById('share-memories-success');
		const containerEl   = document.getElementById('shared-memories-container');
		const loadingEl     = document.getElementById('shared-memories-loading');

		let memoriesList: SharedMemory[] = [];
		let currentIndex = 0;
		let isAnimating = false;
		const likedSet = new Set<number>();

		// ── Share modal ───────────────────────────────────────────
		function openShareModal() {
			if (shareModal)  shareModal.hidden = false;
			if (errorEl)    { errorEl.hidden = true; errorEl.textContent = ''; }
			if (successEl)    successEl.hidden = true;
			if (form)         form.reset();
		}
		function closeShareModal() {
			if (shareModal) shareModal.hidden = true;
		}

		openBtn?.addEventListener('click', openShareModal);
		shareOverlay?.addEventListener('click', closeShareModal);
		cancelBtn?.addEventListener('click', closeShareModal);

		// ── TikTok feed rendering ─────────────────────────────────
		function escapeHtml(s: string) {
			const d = document.createElement('div');
			d.textContent = s;
			return d.innerHTML;
		}

		function slideHTML(idx: number): string {
			const m = memoriesList[idx];
			const liked = likedSet.has(idx);
			const total = memoriesList.length;
			const heartFill  = liked ? '#fe2c55' : 'none';
			const heartStroke = liked ? '#fe2c55' : '#fff';
			return `
<div class="tt-slide" data-index="${idx}">
  <img class="tt-bg" src="${escapeHtml(m.imageUrl)}" alt="Shared memory ${idx + 1}" />
  <div class="tt-gradient"></div>

  <div class="tt-bottom">
    <p class="tt-username">@surf_del_mar</p>
    ${m.caption ? `<p class="tt-caption">${escapeHtml(m.caption)}</p>` : ''}
    ${m.name    ? `<p class="tt-submitter">&#x2014; ${escapeHtml(m.name)}</p>` : ''}
  </div>

  <div class="tt-actions">
    <div class="tt-avatar-wrap">
      <div class="tt-avatar">🏄</div>
    </div>

    <button class="tt-btn tt-heart${liked ? ' tt-liked' : ''}" data-action="like" data-index="${idx}" aria-label="Like">
      <div class="tt-btn-icon">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="${heartFill}" stroke="${heartStroke}" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </div>
      <span class="tt-btn-label">${liked ? '1' : '0'}</span>
    </button>

    <button class="tt-btn tt-comment-btn" data-action="comment" aria-label="Share a memory">
      <div class="tt-btn-icon">
        <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="#fff" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <span class="tt-btn-label">Add</span>
    </button>

    <a class="tt-btn tt-save-btn" href="${escapeHtml(m.imageUrl)}" download="surf-del-mar-memory-${idx + 1}.jpg" aria-label="Download photo">
      <div class="tt-btn-icon">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#fff" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </div>
      <span class="tt-btn-label">Save</span>
    </a>
  </div>

  <div class="tt-counter">${idx + 1} / ${total}</div>
</div>`;
		}

		function attachSlideListeners() {
			const feed = document.getElementById('tt-feed');
			if (!feed) return;

			// Like button
			feed.querySelectorAll('[data-action="like"]').forEach((btn) => {
				btn.addEventListener('click', () => {
					const idx = parseInt((btn as HTMLElement).dataset.index || '0', 10);
					if (likedSet.has(idx)) likedSet.delete(idx);
					else likedSet.add(idx);
					// Re-render just the heart state
					const heartSvg = btn.querySelector('svg');
					const label    = btn.querySelector('.tt-btn-label');
					const liked    = likedSet.has(idx);
					if (heartSvg) {
						heartSvg.setAttribute('fill',   liked ? '#fe2c55' : 'none');
						heartSvg.setAttribute('stroke', liked ? '#fe2c55' : '#fff');
					}
					if (label) label.textContent = liked ? '1' : '0';
					btn.classList.toggle('tt-liked', liked);
					// Bounce animation
					btn.classList.remove('tt-like-pop');
					void (btn as HTMLElement).offsetWidth;
					btn.classList.add('tt-like-pop');
				});
			});

			// Comment → open share modal
			feed.querySelectorAll('[data-action="comment"]').forEach((btn) => {
				btn.addEventListener('click', openShareModal);
			});
		}

		function updateNavButtons() {
			const upBtn   = document.getElementById('tt-up');
			const downBtn = document.getElementById('tt-down');
			if (upBtn)   (upBtn   as HTMLButtonElement).disabled = currentIndex === 0;
			if (downBtn) (downBtn as HTMLButtonElement).disabled = currentIndex === memoriesList.length - 1;
		}

		function updateDots() {
			document.querySelectorAll('.tt-dot').forEach((dot, i) => {
				dot.classList.toggle('active', i === currentIndex);
			});
		}

		async function goTo(newIdx: number, dir: 'up' | 'down') {
			if (isAnimating) return;
			if (newIdx < 0 || newIdx >= memoriesList.length) return;
			isAnimating = true;

			const stage = document.getElementById('tt-stage');
			if (!stage) { isAnimating = false; return; }

			// Build the incoming slide off-screen
			const incoming = document.createElement('div');
			incoming.innerHTML = slideHTML(newIdx);
			const inSlide = incoming.firstElementChild as HTMLElement;
			inSlide.style.position = 'absolute';
			inSlide.style.inset = '0';
			inSlide.style.transform = dir === 'up' ? 'translateY(100%)' : 'translateY(-100%)';
			inSlide.style.transition = 'none';
			stage.appendChild(inSlide);

			// Force reflow so the starting transform is applied
			inSlide.offsetHeight;

			// Animate current slide out and new slide in
			const currentSlide = stage.querySelector('.tt-slide:not(:last-child)') as HTMLElement | null;
			inSlide.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
			inSlide.style.transform  = 'translateY(0)';
			if (currentSlide) {
				currentSlide.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
				currentSlide.style.transform  = dir === 'up' ? 'translateY(-100%)' : 'translateY(100%)';
			}

			await new Promise<void>((r) => setTimeout(r, 420));

			// Swap content cleanly
			stage.innerHTML = slideHTML(newIdx);
			currentIndex = newIdx;
			attachSlideListeners();
			updateNavButtons();
			updateDots();
			isAnimating = false;
		}

		function renderTikTok() {
			if (!containerEl) return;
			const total = memoriesList.length;
			const dots  = memoriesList.map((_, i) => `<div class="tt-dot${i === 0 ? ' active' : ''}"></div>`).join('');

			containerEl.innerHTML = `
<div class="tt-outer">
  <div class="tt-phone-frame">
    <div class="tt-feed" id="tt-feed">
      <div class="tt-stage" id="tt-stage">
        ${slideHTML(0)}
      </div>

      <div class="tt-nav-arrows">
        <button class="tt-nav-btn" id="tt-up" aria-label="Previous memory" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><polyline points="18 15 12 9 6 15"/></svg>
        </button>
        <button class="tt-nav-btn" id="tt-down" aria-label="Next memory" ${total <= 1 ? 'disabled' : ''}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
      </div>
    </div>

    ${total > 1 ? `<div class="tt-dots" aria-hidden="true">${dots}</div>` : ''}
  </div>
</div>`;

			attachSlideListeners();

			// Up/down buttons
			document.getElementById('tt-up')?.addEventListener('click', () => goTo(currentIndex - 1, 'down'));
			document.getElementById('tt-down')?.addEventListener('click', () => goTo(currentIndex + 1, 'up'));

			// Touch swipe
			let touchY = 0;
			const feed = document.getElementById('tt-feed')!;
			feed.addEventListener('touchstart', (e) => { touchY = e.changedTouches[0].clientY; }, { passive: true });
			feed.addEventListener('touchend', (e) => {
				const diff = touchY - e.changedTouches[0].clientY;
				if (Math.abs(diff) > 40) goTo(currentIndex + (diff > 0 ? 1 : -1), diff > 0 ? 'up' : 'down');
			}, { passive: true });

			// Mouse wheel (throttled)
			let wheelCooldown = false;
			feed.addEventListener('wheel', (e) => {
				e.preventDefault();
				if (wheelCooldown) return;
				wheelCooldown = true;
				goTo(currentIndex + (e.deltaY > 0 ? 1 : -1), e.deltaY > 0 ? 'up' : 'down');
				setTimeout(() => { wheelCooldown = false; }, 600);
			}, { passive: false });

			// Keyboard
			document.addEventListener('keydown', (e) => {
				if (e.key === 'ArrowDown') goTo(currentIndex + 1, 'up');
				if (e.key === 'ArrowUp')   goTo(currentIndex - 1, 'down');
			});
		}

		async function renderMemories() {
			if (!containerEl) return;
			const result = await getSharedMemories();
			if (loadingEl) loadingEl.remove();
			if (!result.ok) {
				containerEl.innerHTML = `<p class="shared-memories-msg shared-memories-err">Couldn't load memories. ${escapeHtml(result.error)}</p>`;
				return;
			}
			memoriesList = result.memories.filter((m) => m.imageUrl && m.imageUrl.startsWith('data:') && m.approved !== false);
			if (memoriesList.length === 0) {
				containerEl.innerHTML = '<p class="shared-memories-msg">No memories yet — be the first to share!</p>';
				return;
			}
			currentIndex = 0;
			renderTikTok();
		}

		// ── Form submit ───────────────────────────────────────────
		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!errorEl || !successEl || !fileInput) return;
			errorEl.hidden  = true;
			successEl.hidden = true;
			const file = fileInput.files?.[0];
			if (!file) { errorEl.textContent = 'Please choose a photo.'; errorEl.hidden = false; return; }
			const caption = (document.getElementById('memory-caption') as HTMLTextAreaElement)?.value?.trim() || '';
			const name    = (document.getElementById('memory-name')    as HTMLInputElement)?.value?.trim()    || '';
			const submitBtn = document.getElementById('share-memories-submit') as HTMLButtonElement;
			submitBtn.disabled = true;
			try {
				const { base64, contentType } = await compressImage(file, MAX_IMAGE_SIZE, MAX_DIMENSION);
				if (!base64) { errorEl.textContent = 'Photo too large — try a smaller image.'; errorEl.hidden = false; return; }
				const res  = await fetch(SUBMIT_URL, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ imageBase64: base64, contentType, caption, name }) });
				const data = await res.json().catch(() => ({}));
				if (!res.ok) {
					errorEl.textContent = res.status === 404 ? 'Run "npm run dev:netlify" for local testing.' : ((data?.error) ? String(data.error) : `Error ${res.status}`);
					errorEl.hidden = false; return;
				}
				successEl.hidden = false;
				await renderMemories();
				setTimeout(closeShareModal, 1500);
			} catch (err) {
				errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong.';
				errorEl.hidden = false;
			} finally { submitBtn.disabled = false; }
		});

		async function compressImage(file: File, maxBytes: number, maxDim: number) {
			const contentType = 'image/jpeg';
			if (!file.type.startsWith('image/')) return { base64: null, contentType };
			const img   = await loadImg(file);
			const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
			const canvas = Object.assign(document.createElement('canvas'), { width: Math.round(img.width * scale), height: Math.round(img.height * scale) });
			canvas.getContext('2d')!.drawImage(img, 0, 0, canvas.width, canvas.height);
			for (const q of [0.85, 0.7, 0.55, 0.4, 0.25]) {
				const blob = await new Promise<Blob | null>((r) => canvas.toBlob(r, 'image/jpeg', q));
				if (blob && blob.size <= maxBytes) return { base64: await blobToB64(blob), contentType };
			}
			return { base64: null, contentType };
		}
		function loadImg(file: File) {
			return new Promise<HTMLImageElement>((res, rej) => {
				const url = URL.createObjectURL(file), img = new Image();
				img.onload  = () => { URL.revokeObjectURL(url); res(img); };
				img.onerror = () => { URL.revokeObjectURL(url); rej(new Error('load failed')); };
				img.src = url;
			});
		}
		function blobToB64(blob: Blob) {
			return new Promise<string>((res, rej) => {
				const r = new FileReader();
				r.onload  = () => res((r.result as string).split(',')[1] || '');
				r.onerror = rej;
				r.readAsDataURL(blob);
			});
		}

		renderMemories();
	</script>
</BaseLayout>

<style>
	/* ── Page base ─────────────────────────────────────────────── */
	.hero {
		color: var(--color-cream);
		padding: 4rem 2rem;
		text-align: center;
	}

	.wave-wrap {
		position: relative;
		overflow: visible;
		min-height: 120px;
	}
	.wave-wrap :global(.wave-surfer-wrap) { transition: opacity 0.4s ease, visibility 0.4s ease; }
	:global(.wave-wrap.pirate-mode) :global(.wave-surfer-wrap) { opacity: 0; visibility: hidden; pointer-events: none; }

	.hero-content { max-width: 700px; margin: 0 auto; }

	.hero h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 1rem;
		line-height: 1.2;
	}
	.hero-title  { animation: hero-fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
	.hero-tagline { opacity: 0; animation: hero-fade-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards; }
	@keyframes hero-fade-up {
		from { opacity: 0; transform: translateY(30px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	.tagline { font-size: 1.25rem; opacity: 0.95; font-weight: 400; }

	.reunion-content {
		position: relative;
		z-index: 1;
		padding: 4rem 2rem 0;
		background: linear-gradient(180deg, var(--color-sand) 0%, var(--color-foam) 100%);
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
		padding-bottom: 0;
	}

	.reunion-content .container {
		max-width: 820px;
		margin: 0 auto;
		padding-bottom: 0;
	}

	.reunion-intro-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
		margin-bottom: 2.5rem;
	}
	@media (max-width: 768px) {
		.reunion-intro-grid { grid-template-columns: 1fr; gap: 2rem; }
		.reunion-intro-image-col { order: 1; }
		.reunion-intro-text-col  { order: 2; }
	}

	.reunion-surfers-wrap { display: flex; justify-content: center; align-items: center; }
	.reunion-surfers-img {
		width: 100%; max-width: 380px; height: auto; display: block;
		border-radius: 6px;
		box-shadow: 0 20px 50px rgba(0,0,0,0.18), 0 8px 24px rgba(0,0,0,0.12);
		transform: rotate(-2deg);
		transition: transform 0.35s ease, box-shadow 0.35s ease;
	}
	.reunion-surfers-wrap:hover .reunion-surfers-img { transform: rotate(0deg); box-shadow: 0 24px 56px rgba(0,0,0,0.2); }

	.reunion-intro-text-col .reunion-intro { margin-top: 0; }
	.reunion-intro { font-family: var(--font-body); font-size: 1.0625rem; color: var(--color-ink); line-height: 1.75; margin: 0 0 1rem 0; }
	.reunion-intro:last-of-type { margin-bottom: 0; }

	.reunion-subhead {
		font-family: var(--font-body);
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		font-weight: 700;
		letter-spacing: 0.08em;
