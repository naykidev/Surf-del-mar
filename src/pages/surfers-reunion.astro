---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollWaves from '../components/ScrollWaves.astro';
import WaveSurfer from '../components/WaveSurfer.astro';
import PirateShip from '../components/PirateShip.astro';
import Lighthouse from '../components/Lighthouse.astro';
---

<BaseLayout
	title="Surfers Reunion"
	description="A gathering of generations—Del Mar surfers past and present, together again."
	pageKey="surfers-reunion"
>
	<section class="hero hero-sunset-bg">
		<div class="hero-content hero-entrance">
			<h1 class="hero-title" data-editable="reunion.hero.title">SURFERS REUNION</h1>
			<p class="tagline hero-tagline" data-editable="reunion.hero.tagline">A Gathering of Generations</p>
		</div>
	</section>
	<div class="wave-wrap wave-hero hero-sunset-bg" id="reunion-wave-wrap">
		<ScrollWaves variant="light" />
		<WaveSurfer />
		<PirateShip />
		<Lighthouse toggleTargetId="reunion-wave-wrap" />
	</div>

	<section class="reunion-content">
		<div class="container">
			<div class="reunion-intro-body">
				<p class="reunion-intro" data-editable="reunion.intro1">
					For decades, surfers have gathered along our local beaches to ride the waves, and share stories, building a unique coastal culture. SURF DEL MAR brings these generations together again.
				</p>
				<div class="reunion-img-wrap">
					<img src="/surferreunion1.png" alt="Surfers Reunion" class="reunion-section-img" width="1136" height="752" />
					<div class="tape-element"></div>
				</div>
				<div class="reunion-img-wrap">
					<img src="/surferreunion5.png" alt="Surfers Reunion" class="reunion-section-img" width="1228" height="746" />
					<div class="tape-element"></div>
				</div>
				<p class="reunion-intro">
					From the pioneers who surfed here in the 1930s and into the 1950s and 60s, to today's surfers and young riders, this reunion invites everyone connected to Del Mar and the surrounding surf communities to come together and celebrate.
				</p>
				<div class="reunion-img-wrap">
					<img src="/surferreunion2.png" alt="Surfers Reunion" class="reunion-section-img" width="1330" height="748" />
					<div class="tape-element"></div>
				</div>
				<div class="reunion-img-wrap">
					<img src="/surferreunion3.png" alt="Surfers Reunion" class="reunion-section-img" width="1212" height="752" />
					<div class="tape-element"></div>
				</div>
			</div>

			<h2 class="reunion-subhead" data-editable="reunion.subhead1">REMEMBERING THE WAVES</h2>
			<p class="reunion-lead" data-editable="reunion.lead">Throughout the SURF DEL MAR weekend, reunion events will include;</p>
			<ul class="reunion-list">
				<li data-editable="reunion.list.1">Informal gatherings and storytelling with surfers from different eras</li>
				<li data-editable="reunion.list.2">Historic photographs and shared memories from Del Mar's early surf days</li>
				<li data-editable="reunion.list.3">Film screenings celebrating classic surf culture</li>
				<li data-editable="reunion.list.4">Music and community events bringing surfers, families and friends together</li>
			</ul>
			<article class="event-card">
				<p class="reunion-body" data-editable="reunion.body1">
					The reunion is about reconnecting with old friends, meeting new ones, and honoring the shared love of the ocean that has defined Del Mar and its neighbors for generations.
				</p>
			</article>
			<div class="reunion-img-wrap">
				<img src="/surferreunion4.jpg" alt="Surfers Reunion" class="reunion-section-img" width="3600" height="2448" />
				<div class="tape-element"></div>
			</div>

			<h2 class="reunion-subhead" data-editable="reunion.subhead2">BE PART OF THE REUNION:</h2>
			<article class="event-card">
				<p class="reunion-body" data-editable="reunion.body2">
					Just like the Beach Boys song says, "You'll catch 'em surfin' at Del Mar," whether you surfed these waves decades ago or just recently discovered them, SURF DEL MAR welcomes you! Come celebrate the history, the stories and the community that grew from the surf at Del Mar.
				</p>
			</article>

			<article class="event-card event-card-cta">
				<h2 class="reunion-cta-heading" data-editable="reunion.cta-heading">DO YOU HAVE A DEL MAR SURF STORY? SHARE IT WITH EVERYONE!</h2>
				<p class="reunion-cta-body" data-editable="reunion.cta-body">
					Send us your photos, your memories and names of people we should invite. We'll include them in the SHARED MEMORIES section below.
				</p>
				<button type="button" class="reunion-share-btn" id="reunion-share-memories-btn">Share your memories</button>
			</article>

			<h2 class="reunion-subhead reunion-memories-heading">SHARED MEMORIES</h2>
		</div>

		<div id="shared-memories-container" class="shared-memories-container" aria-live="polite">
			<p id="shared-memories-loading" class="shared-memories-msg">Loading…</p>
		</div>
	</section>

	<!-- Share memories modal -->
	<div id="share-memories-modal" class="share-memories-modal" role="dialog" aria-labelledby="share-memories-title" aria-modal="true" hidden>
		<div class="share-memories-overlay" id="share-memories-overlay"></div>
		<div class="share-memories-box">
			<h2 id="share-memories-title" class="share-memories-title">Share your memories</h2>
			<form id="share-memories-form" class="share-memories-form">
				<label for="memory-photo" class="share-memories-label">Photo</label>
				<input type="file" id="memory-photo" name="photo" accept="image/*" required class="share-memories-file" />
				<label for="memory-caption" class="share-memories-label">Your memory (optional)</label>
				<textarea id="memory-caption" name="caption" class="share-memories-textarea" rows="3" placeholder="Tell us about this photo…" maxlength="1000"></textarea>
				<label for="memory-name" class="share-memories-label">Your name (optional)</label>
				<input type="text" id="memory-name" name="name" class="share-memories-input" placeholder="Name" maxlength="200" />
				<p id="share-memories-error" class="share-memories-error" aria-live="polite" hidden></p>
				<p id="share-memories-success" class="share-memories-success" aria-live="polite" hidden>Thank you! Your memory has been added.</p>
				<div class="share-memories-actions">
					<button type="button" class="share-memories-btn share-memories-cancel" id="share-memories-cancel">Cancel</button>
					<button type="submit" class="share-memories-btn share-memories-submit" id="share-memories-submit">Submit</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		import { getSharedMemories, getMemoryComments, likeMemory } from '../lib/firebase';
		import type { SharedMemory, MemoryComment } from '../lib/firebase';

		const SUBMIT_URL      = '/.netlify/functions/submit-memory';
		const COMMENT_URL     = '/.netlify/functions/add-comment';
		const MAX_IMAGE_SIZE  = 700 * 1024;
		const MAX_DIMENSION   = 1200;
		const LIKED_LS_KEY    = 'sdm_liked_v2';
		const FP_LS_KEY       = 'sdm_fp';

		// Share modal refs
		const openBtn      = document.getElementById('reunion-share-memories-btn');
		const shareModal   = document.getElementById('share-memories-modal');
		const shareOverlay = document.getElementById('share-memories-overlay');
		const form         = document.getElementById('share-memories-form') as HTMLFormElement | null;
		const cancelBtn    = document.getElementById('share-memories-cancel');
		const fileInput    = document.getElementById('memory-photo') as HTMLInputElement;
		const errorEl      = document.getElementById('share-memories-error');
		const successEl    = document.getElementById('share-memories-success');
		const containerEl  = document.getElementById('shared-memories-container');
		const loadingEl    = document.getElementById('shared-memories-loading');

		let memoriesList: SharedMemory[] = [];
		let currentIndex = 0;
		let isAnimating  = false;

		// Per-memory likes state (count + whether user has liked)
		const likesMap = new Map<string, { count: number; liked: boolean }>();
		// Per-memory comments cache
		const commentsCache = new Map<string, MemoryComment[]>();

		// ── localStorage helpers ──────────────────────────────────
		function getFingerprint(): string {
			try {
				let fp = localStorage.getItem(FP_LS_KEY);
				if (!fp) { fp = Math.random().toString(36).slice(2) + Date.now().toString(36); localStorage.setItem(FP_LS_KEY, fp); }
				return fp;
			} catch { return ''; }
		}
		function getLocalLiked(): Set<string> {
			try { return new Set(JSON.parse(localStorage.getItem(LIKED_LS_KEY) || '[]')); } catch { return new Set(); }
		}
		function addLocalLiked(memoryId: string) {
			try { const s = getLocalLiked(); s.add(memoryId); localStorage.setItem(LIKED_LS_KEY, JSON.stringify([...s])); } catch {}
		}

		// ── Share modal ───────────────────────────────────────────
		function openShareModal() {
			if (shareModal)  shareModal.hidden = false;
			if (errorEl)    { errorEl.hidden = true; errorEl.textContent = ''; }
			if (successEl)   successEl.hidden = true;
			if (form)        form.reset();
		}
		function closeShareModal() { if (shareModal) shareModal.hidden = true; }

		openBtn?.addEventListener('click', openShareModal);
		shareOverlay?.addEventListener('click', closeShareModal);
		cancelBtn?.addEventListener('click', closeShareModal);

		// ── HTML helpers ──────────────────────────────────────────
		function esc(s: string): string {
			const d = document.createElement('div');
			d.textContent = s;
			return d.innerHTML;
		}

		function slideHTML(idx: number): string {
			const m     = memoriesList[idx];
			const total = memoriesList.length;
			const localLiked = getLocalLiked();
			const liked = localLiked.has(m.id);
			const count = likesMap.get(m.id)?.count ?? m.likes ?? 0;

			return `
<div class="reel-slide" data-index="${idx}" data-memory-id="${esc(m.id)}">
  <img class="reel-photo" src="${esc(m.imageUrl)}" alt="Shared memory ${idx + 1} of ${total}" />
  <div class="reel-gradient" aria-hidden="true"></div>
  <div class="reel-dbl-heart" id="reel-heart-${esc(m.id)}" aria-hidden="true">❤️</div>

  <div class="reel-info">
    <p class="reel-username">🏄 <strong>surf_del_mar</strong></p>
    ${m.caption ? `<p class="reel-caption">${esc(m.caption)}</p>` : ''}
    ${m.name    ? `<p class="reel-by">&#x2014; ${esc(m.name)}</p>` : ''}
    <p class="reel-swipe-hint" aria-hidden="true">↑ swipe for next</p>
  </div>

  <div class="reel-sidebar">
    <button class="reel-like-btn${liked ? ' reel-liked' : ''}" data-action="like" data-memory-id="${esc(m.id)}" aria-label="Like">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="${liked ? '#e0245e' : 'none'}" stroke="${liked ? '#e0245e' : '#fff'}" stroke-width="1.75">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span id="ig-like-count-${esc(m.id)}">${count}</span>
    </button>
    <button class="reel-cmt-btn" data-action="toggle-comments" data-memory-id="${esc(m.id)}" aria-label="Comments">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="#fff" stroke-width="1.75">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <span id="reel-cmt-count-${esc(m.id)}">…</span>
    </button>
    <a class="reel-save-btn" href="${esc(m.imageUrl)}" download="surf-del-mar-memory-${idx + 1}.jpg" aria-label="Save photo">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#fff" stroke-width="1.75">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      <span>Save</span>
    </a>
    ${total > 1 ? `<div class="reel-counter">${idx + 1}<span>/${total}</span></div>` : ''}
  </div>

  <div class="reel-comments-panel" id="tt-comments-section-${esc(m.id)}">
    <button class="reel-cmts-backdrop" data-action="toggle-comments" data-memory-id="${esc(m.id)}" aria-label="Close comments"></button>
    <div class="reel-cmts-sheet">
      <div class="reel-cmts-handle" aria-hidden="true"></div>
      <div class="reel-cmts-header">
        <span class="reel-cmts-title">Comments <span class="tt-comment-count" id="tt-comment-count-${esc(m.id)}"></span></span>
        <button class="reel-cmts-close" data-action="toggle-comments" data-memory-id="${esc(m.id)}" aria-label="Close">&#x2715;</button>
      </div>
      <div class="tt-comments-list" id="tt-comments-list-${esc(m.id)}">
        <p class="tt-comment-placeholder">Loading…</p>
      </div>
      <form class="reel-cmt-form" id="tt-comment-form" data-memory-id="${esc(m.id)}" novalidate>
        <div class="reel-cmt-row">
          <input type="text" id="tt-cmt-text" class="reel-cmt-input" placeholder="Add a comment…" maxlength="500" />
          <button type="submit" class="ig-cmt-post">Post</button>
        </div>
        <input type="text" id="tt-cmt-name" class="reel-name-input" placeholder="Your name (optional)" maxlength="100" autocomplete="name" />
        <p id="tt-cmt-error" class="reel-cmt-error" hidden></p>
      </form>
    </div>
  </div>
</div>`;
		}

		// ── Comments ──────────────────────────────────────────────
		async function loadAndRenderComments(memoryId: string) {
			const listEl  = document.getElementById(`tt-comments-list-${memoryId}`);
			const countEl = document.getElementById(`tt-comment-count-${memoryId}`);
			if (!listEl) return;

			if (!commentsCache.has(memoryId)) {
				const comments = await getMemoryComments(memoryId);
				commentsCache.set(memoryId, comments);
			}
			renderCommentsList(memoryId, listEl, countEl);
		}

		function renderCommentsList(memoryId: string, listEl: Element, countEl: Element | null) {
			const comments = commentsCache.get(memoryId) || [];
			const n = comments.length;
			if (countEl) countEl.textContent = `(${n})`;
			const sidebarCount = document.getElementById(`reel-cmt-count-${memoryId}`);
			if (sidebarCount) sidebarCount.textContent = String(n);
			if (n === 0) {
				listEl.innerHTML = '<p class="tt-comment-placeholder">No comments yet — be the first!</p>';
				return;
			}
			listEl.innerHTML = comments.map(c => `
				<div class="tt-comment">
					<span class="tt-cmt-name">${c.name ? esc(c.name) : 'Anonymous'}</span>
					<span class="tt-cmt-text">${esc(c.text)}</span>
				</div>
			`).join('');
			listEl.scrollTop = listEl.scrollHeight;
		}

		function toggleComments(memoryId: string) {
			const section = document.getElementById(`tt-comments-section-${memoryId}`);
			if (!section) return;
			const opening = !section.classList.contains('open');
			section.classList.toggle('open');
			if (opening) loadAndRenderComments(memoryId);
		}

		// ── Likes ─────────────────────────────────────────────────
		function setLikeUI(btn: HTMLElement, count: number, liked: boolean) {
			const svg = btn.querySelector('svg');
			if (svg) { svg.setAttribute('fill', liked ? '#e0245e' : 'none'); svg.setAttribute('stroke', liked ? '#e0245e' : '#fff'); }
			btn.classList.toggle('reel-liked', liked);
			if (liked) { btn.classList.remove('tt-like-pop'); void btn.offsetWidth; btn.classList.add('tt-like-pop'); }
			const memId = btn.dataset.memoryId!;
			const likesEl = document.getElementById(`ig-like-count-${memId}`);
			if (likesEl) likesEl.textContent = String(count);
		}

		async function handleLike(memoryId: string, btn: HTMLElement) {
			const localLiked = getLocalLiked();
			if (localLiked.has(memoryId)) return;

			// Optimistic update
			const state    = likesMap.get(memoryId) ?? { count: memoriesList.find(m => m.id === memoryId)?.likes ?? 0, liked: false };
			const prevCount = state.count;
			state.count += 1;
			state.liked  = true;
			likesMap.set(memoryId, state);
			addLocalLiked(memoryId);
			setLikeUI(btn, state.count, true);

			try {
				await likeMemory(memoryId, getFingerprint());
			} catch (err) {
				// Revert on failure
				console.error('[SDM] like failed:', err);
				state.count = prevCount;
				state.liked = false;
				likesMap.set(memoryId, state);
				try { const s = getLocalLiked(); s.delete(memoryId); localStorage.setItem(LIKED_LS_KEY, JSON.stringify([...s])); } catch {}
				setLikeUI(btn, prevCount, false);
			}
		}

		// ── Attach event listeners to current slide ───────────────
		function attachSlideListeners() {
			const card = document.getElementById('tt-card');
			if (!card) return;

			// Like
			card.querySelectorAll('[data-action="like"]').forEach((btn) => {
				btn.addEventListener('click', () => handleLike((btn as HTMLElement).dataset.memoryId!, btn as HTMLElement));
			});

			// Toggle comments (both the bubble button and the ✕ close button)
			card.querySelectorAll('[data-action="toggle-comments"]').forEach((btn) => {
				btn.addEventListener('click', () => toggleComments((btn as HTMLElement).dataset.memoryId!));
			});

			// Comment form
			const commentForm = document.getElementById('tt-comment-form') as HTMLFormElement | null;
			commentForm?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const memId  = commentForm.dataset.memoryId!;
				const textEl = document.getElementById('tt-cmt-text') as HTMLInputElement;
				const nameEl = document.getElementById('tt-cmt-name') as HTMLInputElement;
				const errEl  = document.getElementById('tt-cmt-error');
				const text   = textEl.value.trim();
				const name   = nameEl.value.trim();
				if (!text) { textEl.focus(); return; }

				const postBtn = commentForm.querySelector('.ig-cmt-post') as HTMLButtonElement;
				postBtn.disabled = true;
				postBtn.textContent = '…';
				if (errEl) errEl.hidden = true;

				try {
					const res = await fetch(COMMENT_URL, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ memoryId: memId, text, name }),
					});
					if (!res.ok) throw new Error('Post failed');

					// Optimistically add to cache and re-render
					const cached = commentsCache.get(memId) ?? [];
					cached.push({ id: Date.now().toString(), text, name, submittedAt: null });
					commentsCache.set(memId, cached);
					const listEl  = document.getElementById(`tt-comments-list-${memId}`);
					const countEl = document.getElementById(`tt-comment-count-${memId}`);
					if (listEl) renderCommentsList(memId, listEl, countEl);
					textEl.value = '';
				} catch {
					if (errEl) { errEl.textContent = 'Failed to post. Try again.'; errEl.hidden = false; }
				} finally {
					postBtn.disabled = false;
					postBtn.textContent = 'Post';
				}
			});

			// Vertical swipe + double-tap on the whole slide
			const slide = card.querySelector('.reel-slide') as HTMLElement | null;
			if (slide) {
				let touchY = 0;
				slide.addEventListener('touchstart', (e) => { touchY = (e as TouchEvent).changedTouches[0].clientY; }, { passive: true });
				slide.addEventListener('touchend', (e) => {
					const diff = touchY - (e as TouchEvent).changedTouches[0].clientY;
					if (Math.abs(diff) > 50) goTo(currentIndex + (diff > 0 ? 1 : -1), diff > 0 ? 'left' : 'right');
				}, { passive: true });

				let lastTap = 0;
				slide.addEventListener('click', (e) => {
					if ((e.target as Element).closest('button, a, form, input')) return;
					const now = Date.now();
					if (now - lastTap < 350) {
						const memId = slide.dataset.memoryId!;
						const likeBtn = slide.querySelector(`[data-action="like"]`) as HTMLElement | null;
						if (likeBtn) handleLike(memId, likeBtn);
						const heartEl = document.getElementById(`reel-heart-${memId}`);
						if (heartEl) { heartEl.classList.remove('reel-heart-pop'); void heartEl.offsetWidth; heartEl.classList.add('reel-heart-pop'); }
					}
					lastTap = now;
				});
			}
		}

		// ── Navigation ────────────────────────────────────────────
		function updateNavButtons() {
			// Arrows are rendered conditionally in slideHTML — nothing to toggle here
		}

		function updateDots() {
			document.querySelectorAll('.tt-dot').forEach((d, i) => d.classList.toggle('active', i === currentIndex));
		}

		async function goTo(newIdx: number, dir: 'left' | 'right') {
			if (isAnimating || newIdx < 0 || newIdx >= memoriesList.length) return;
			isAnimating = true;

			const stage = document.getElementById('tt-stage');
			if (!stage) { isAnimating = false; return; }

			// Build incoming slide: 'left' = next = comes from bottom; 'right' = prev = comes from top
			const tmp = document.createElement('div');
			tmp.innerHTML = slideHTML(newIdx).trim();
			const inSlide = tmp.firstElementChild as HTMLElement;
			Object.assign(inSlide.style, {
				position: 'absolute', inset: '0',
				transform: dir === 'left' ? 'translateY(100%)' : 'translateY(-100%)',
				transition: 'none', zIndex: '2',
			});
			stage.appendChild(inSlide);
			inSlide.offsetHeight;

			const outSlide = stage.querySelector('.reel-slide:not(:last-child)') as HTMLElement | null;
			const ty = dir === 'left' ? '-100%' : '100%';
			const ease = 'transform 0.42s cubic-bezier(0.4,0,0.2,1)';
			inSlide.style.transition = ease;
			inSlide.style.transform  = 'translateY(0)';
			if (outSlide) { outSlide.style.transition = ease; outSlide.style.transform = `translateY(${ty})`; }

			await new Promise<void>((r) => setTimeout(r, 440));

			stage.innerHTML = slideHTML(newIdx).trim();
			currentIndex = newIdx;
			attachSlideListeners();
			updateDots();
			loadAndRenderComments(memoriesList[newIdx].id);
			isAnimating = false;
		}

		// ── Render feed ───────────────────────────────────────────
		function renderFeed() {
			if (!containerEl) return;
			containerEl.innerHTML = `
<div class="tt-outer">
  <div class="tt-card" id="tt-card">
    <div class="tt-stage" id="tt-stage">
      ${slideHTML(0).trim()}
    </div>
  </div>
</div>`;

			attachSlideListeners();
			loadAndRenderComments(memoriesList[0].id);

			document.addEventListener('keydown', (e) => {
				if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') return;
				if (e.key === 'ArrowDown' || e.key === 'ArrowRight') goTo(currentIndex + 1, 'left');
				if (e.key === 'ArrowUp'   || e.key === 'ArrowLeft')  goTo(currentIndex - 1, 'right');
			});
		}

		async function renderMemories() {
			if (!containerEl) return;
			const result = await getSharedMemories();
			if (loadingEl) loadingEl.remove();
			if (!result.ok) {
				containerEl.innerHTML = `<p class="shared-memories-msg shared-memories-err">Couldn't load memories. ${esc(result.error)}</p>`;
				return;
			}
			memoriesList = result.memories.filter((m) => m.imageUrl && m.imageUrl.startsWith('data:') && m.approved !== false);
			if (memoriesList.length === 0) {
				containerEl.innerHTML = '<p class="shared-memories-msg">No memories yet — be the first to share!</p>';
				return;
			}
			// Seed likes state from Firestore data + localStorage
			const localLiked = getLocalLiked();
			for (const m of memoriesList) {
				likesMap.set(m.id, { count: m.likes ?? 0, liked: localLiked.has(m.id) });
			}
			currentIndex = 0;
			renderFeed();
		}

		// ── Submit new memory form ────────────────────────────────
		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!errorEl || !successEl || !fileInput) return;
			errorEl.hidden  = true;
			successEl.hidden = true;
			const file = fileInput.files?.[0];
			if (!file) { errorEl.textContent = 'Please choose a photo.'; errorEl.hidden = false; return; }
			const caption = (document.getElementById('memory-caption') as HTMLTextAreaElement)?.value?.trim() || '';
			const name    = (document.getElementById('memory-name')    as HTMLInputElement)?.value?.trim()    || '';
			const submitBtn = document.getElementById('share-memories-submit') as HTMLButtonElement;
			submitBtn.disabled = true;
			try {
				const { base64, contentType } = await compressImage(file, MAX_IMAGE_SIZE, MAX_DIMENSION);
				if (!base64) { errorEl.textContent = 'Photo too large — try a smaller image.'; errorEl.hidden = false; return; }
				const res  = await fetch(SUBMIT_URL, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ imageBase64: base64, contentType, caption, name }) });
				const data = await res.json().catch(() => ({}));
				if (!res.ok) {
					errorEl.textContent = res.status === 404 ? 'Run "npm run dev:netlify" for local testing.' : ((data?.error) ? String(data.error) : `Error ${res.status}`);
					errorEl.hidden = false; return;
				}
				successEl.hidden = false;
				await renderMemories();
				setTimeout(closeShareModal, 1500);
			} catch (err) {
				errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong.';
				errorEl.hidden = false;
			} finally { submitBtn.disabled = false; }
		});

		async function compressImage(file: File, maxBytes: number, maxDim: number) {
			const contentType = 'image/jpeg';
			if (!file.type.startsWith('image/')) return { base64: null, contentType };
			const img = await new Promise<HTMLImageElement>((res, rej) => {
				const url = URL.createObjectURL(file), i = new Image();
				i.onload  = () => { URL.revokeObjectURL(url); res(i); };
				i.onerror = () => { URL.revokeObjectURL(url); rej(new Error('load')); };
				i.src = url;
			});
			const scale  = Math.min(1, maxDim / Math.max(img.width, img.height));
			const canvas = Object.assign(document.createElement('canvas'), { width: Math.round(img.width * scale), height: Math.round(img.height * scale) });
			canvas.getContext('2d')!.drawImage(img, 0, 0, canvas.width, canvas.height);
			for (const q of [0.85, 0.7, 0.55, 0.4, 0.25]) {
				const blob = await new Promise<Blob | null>((r) => canvas.toBlob(r, 'image/jpeg', q));
				if (blob && blob.size <= maxBytes) {
					const base64 = await new Promise<string>((res, rej) => {
						const reader = new FileReader();
						reader.onload  = () => res((reader.result as string).split(',')[1] || '');
						reader.onerror = rej;
						reader.readAsDataURL(blob);
					});
					return { base64, contentType };
				}
			}
			return { base64: null, contentType };
		}

		renderMemories();
	</script>
</BaseLayout>

