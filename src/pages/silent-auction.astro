						<span class="auction-label">Opening Bid</span>
						<span class="auction-price">$—</span>
					</div>
				</article>
			</div>
			-->

			<article class="event-card info-card">
				<h3 class="info-title">How the Auction Works</h3>
				<ul class="info-list">
					<li>Browse items on display at the festival venue.</li>
					<li>Write your name, contact info, and bid amount on the bid sheet beside each item.</li>
					<li>The highest bid at closing time wins.</li>
					<li>Winners will be notified and must collect their item before the end of the event.</li>
				</ul>
			</article>

		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		color: var(--color-cream);
		padding: 4rem 2rem;
		text-align: center;
	}

	.wave-wrap {
		position: relative;
		overflow: visible;
		min-height: 120px;
	}

	.wave-wrap :global(.wave-surfer-wrap) {
		transition: opacity 0.4s ease, visibility 0.4s ease;
	}
	:global(.wave-wrap.pirate-mode) :global(.wave-surfer-wrap) {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.hero-content {
		max-width: 700px;
		margin: 0 auto;
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: clamp(2rem, 5vw, 3.75rem);
		font-weight: 600;
		color: var(--color-cream);
		margin: 0 0 1rem;
		line-height: 1.2;
		animation: hero-fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}

	.hero-tagline {
		font-size: 1.2rem;
		opacity: 0;
		font-weight: 400;
		animation: hero-fade-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
	}

	@keyframes hero-fade-up {
		from { opacity: 0; transform: translateY(30px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	.auction-content {
		position: relative;
		z-index: 1;
		padding: 4rem 2rem;
		background: linear-gradient(180deg, var(--color-sand) 0%, var(--color-foam) 100%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
	}

	.container {
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.auction-intro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.75;
		max-width: 720px;
	}

	.section-heading {
		font-family: var(--font-display);
		font-size: clamp(1.4rem, 3vw, 1.85rem);
		font-weight: 600;
		color: var(--color-ink);
		margin: 0.5rem 0 0;
		line-height: 1.3;
	}

	.coming-soon {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		font-style: italic;
		color: var(--color-sepia);
		margin: 0;
	}

	.items-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	@media (max-width: 640px) {
		.items-grid {
			grid-template-columns: 1fr;
		}
	}

	.event-card {
		background: rgba(184, 220, 228, 0.55);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		padding: 1.5rem 1.5rem 1.5rem 1.25rem;
		border-radius: 12px;
		border: 1px solid rgba(255, 255, 255, 0.5);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
		border-left: 6px solid var(--color-accent);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.event-card:hover {
		transform: translateX(6px);
		box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
	}

	.auction-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.auction-lot {
		font-family: var(--font-body);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-accent);
	}

	.auction-item-title {
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-weight: 600;
		color: var(--color-ink);
		line-height: 1.2;
		margin: 0;
	}

	.auction-item-desc {
		font-family: var(--font-body);
		font-size: 0.9375rem;
		color: var(--color-sepia);
		line-height: 1.6;
		margin: 0;
		flex: 1;
	}

	.auction-bid-row {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		margin-top: 0.25rem;
		padding-top: 0.75rem;
		border-top: 1px solid rgba(255, 255, 255, 0.5);
	}

	.auction-label {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--color-sepia);
	}

	.auction-price {
		font-family: var(--font-body);
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--color-accent);
	}

	.info-card {
		padding: 1.75rem 1.5rem 1.75rem 1.25rem;
	}

	.info-title {
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 1rem;
	}

	.info-list {
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.info-list li {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.hero {
			padding: 3rem 1rem;
		}
		.auction-content {
			padding: 2.5rem 1rem;
		}
		.event-card:hover {
			transform: none;
		}
	}
</style>
