---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollWaves from '../components/ScrollWaves.astro';
import WaveSurfer from '../components/WaveSurfer.astro';
import PirateShip from '../components/PirateShip.astro';
import Lighthouse from '../components/Lighthouse.astro';
---

<BaseLayout
	title="Silent Auction"
	description="Bid on unique surf memorabilia, art, and collectibles at the Surf Del Mar Silent Auction."
	pageKey="silent-auction"
>
	<section class="hero hero-sunset-bg">
		<div class="hero-content hero-entrance">
			<h1 class="hero-title">SILENT AUCTION</h1>
			<p class="tagline hero-tagline">Rare surf memorabilia, artwork, and collectibles — bid to take home a piece of history.</p>
		</div>
	</section>
	<div class="wave-wrap wave-hero hero-sunset-bg" id="auction-wave-wrap">
		<ScrollWaves variant="light" />
		<WaveSurfer />
		<PirateShip />
		<Lighthouse toggleTargetId="auction-wave-wrap" />
	</div>

	<section class="auction-content">
		<div class="container">

			<p class="auction-intro">
				The Surf Del Mar Silent Auction features one-of-a-kind items celebrating the history and culture of Del Mar surfing. All proceeds support the Del Mar Historical Society and the Surfing Festival.
			</p>

			<h2 class="section-heading">AUCTION ITEMS</h2>

			<p class="coming-soon">Auction items coming soon.</p>

